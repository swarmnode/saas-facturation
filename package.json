{
  "name": "saas-facturation",
  "version": "2.9.0",
  "description": "SaaS Devis & Facturation France — Loi anti-fraude TVA, Factur-X",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server/index.ts",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');function cp(s,d){if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const sp=path.join(s,f),dp=path.join(d,f);fs.statSync(sp).isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp)}}cp('src/client','dist/client');fs.readdirSync('src/server/db').filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(path.join('src/server/db',f),path.join('dist/server/db',f)))\"",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.32.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.4",
    "docx": "^9.7.1",
    "nodemon": "^3.1.0",
    "playwright": "^1.60.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
